{
  "name": "sap-technologies-server",
  "version": "1.0.0",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "dev:inspect": "nodemon --inspect src/app.js",
    "build": "npm ci --include=dev",
    "postinstall": "echo 'Backend dependencies installed successfully'",
    "cleanup-logs": "node cleanup-logs.js",
    "keep-alive": "node scripts/keep-alive-server.js",
    "seed:admin": "node scripts/admin-seed.js",
    "db:mirror:sync": "node scripts/sync-database-mirror.js",
    "db:mirror:sync:exact": "node scripts/sync-database-mirror.js --prune",
    "db:mirror:sync:prune": "node scripts/sync-database-mirror.js --prune",
    "db:mirror:sync:reverse": "node scripts/sync-database-mirror.js --reverse",
    "db:mirror:sync:reverse:exact": "node scripts/sync-database-mirror.js --reverse --prune",
    "db:mirror:sync:reverse:prune": "node scripts/sync-database-mirror.js --reverse --prune"
  },
  "keywords": [
    "express",
    "mongodb",
    "api",
    "sap-technologies",
    "mvc"
  ],
  "author": "SapTech Uganda",
  "license": "ISC",
  "description": "Express API server for SapTech Uganda website built with MVC architecture",
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "africastalking": "^0.8.0",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "canvas": "^3.2.0",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "connect-mongo": "^5.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^5.1.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.17.3",
    "express-slow-down": "^3.0.0",
    "express-validator": "^7.2.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.18.1",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^2.2.1",
    "node-cache": "^5.1.2",
    "nodemailer": "^8.0.7",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "resend": "^6.1.3",
    "secure-random-password": "^0.2.3",
    "sharp": "^0.34.5",
    "twilio": "^4.19.0",
    "ua-parser-js": "^1.0.41",
    "validator": "^13.15.15",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
