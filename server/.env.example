# SAPTech Uganda Server Environment Configuration
# Copy this file to .env and update with your actual values

# ===========================================
# 🛡️  SECURITY CONFIGURATION
# ===========================================

# Application Environment
NODE_ENV=development
PORT=5000

# ===========================================
# 🔐 DATABASE CONFIGURATION
# ===========================================

# MongoDB Atlas Configuration (Primary)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/sap-technologies?retryWrites=true&w=majority&ssl=true

# MongoDB Atlas Configuration (Secondary / mirror cluster)
# Use a different Atlas cluster with the same database name.
MONGODB_SECONDARY_URI=mongodb+srv://username:password@cluster1.xxxxx.mongodb.net/sap-technologies?retryWrites=true&w=majority&ssl=true

# Dual-cluster behavior
# - Startup failover is automatic when MONGODB_SECONDARY_URI is set.
# - Write mirroring is opt-in so you can run an initial sync first.
MONGODB_MIRROR_ENABLED=false
MONGODB_MIRROR_RETRY_MS=60000
MONGODB_MIRROR_TIMEOUT_MS=5000
MONGODB_MIRROR_OUTBOX_REPLAY_MS=30000
MONGODB_MIRROR_OUTBOX_BATCH_SIZE=250
MONGODB_MIRROR_CATCH_UP_ENABLED=true
MONGODB_MIRROR_CATCH_UP_INTERVAL_MS=300000
MONGODB_MIRROR_CATCH_UP_BATCH_SIZE=500
MONGODB_MIRROR_VERIFY_RETRIES=5
MONGODB_MIRROR_LIVE_TAIL=true
# Active cluster is treated as source-of-truth; prune removes extra documents
# from the recovered mirror cluster during catch-up.
MONGODB_MIRROR_CATCH_UP_PRUNE=true

# Local MongoDB Fallback (Development)
MONGODB_LOCAL=mongodb://localhost:27017/sap-technologies

# Database Security Options
DB_SSL_VALIDATE=true
DB_TLS=true
DB_AUTH_SOURCE=admin
DB_READ_PREFERENCE=primary

# ===========================================
# 🔑 AUTHENTICATION & SESSIONS
# ===========================================

# Session Secret (Generate with: require('crypto').randomBytes(32).toString('hex'))
SESSION_SECRET=your_secure_random_session_secret_here_minimum_32_characters

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
JWT_EXPIRES_IN=24h
JWT_COOKIE_EXPIRES_IN=1

# Password Security
BCRYPT_ROUNDS=12

# ===========================================
# 📧 EMAIL SERVICES (Optional)
# ===========================================

# Brand/contact details included in every professional email
EMAIL_FROM_NAME=SAPTech Uganda
EMAIL_FROM_ADDRESS=info@saptechug.com
EMAIL_REPLY_TO=info@saptechug.com
NOTIFY_EMAIL=info@saptechug.com
COMPANY_EMAIL=info@saptechug.com
COMPANY_LEGAL_NAME=SAPTech Uganda
COMPANY_PHONE=+256706564628
COMPANY_ADDRESS=Ndejje, Kampala, Uganda
AWARDS_BRAND_NAME=SAPTech Awards 2026

# Nodemailer SMTP/Gmail configuration.
# SMTP_* and GMAIL_* are only for sending/authentication; public emails use EMAIL_FROM_ADDRESS and EMAIL_REPLY_TO above.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FROM_EMAIL=saptechnologies256@gmail.com
SMTP_POOL=true
SMTP_MAX_CONNECTIONS=3
SMTP_MAX_MESSAGES=75
GMAIL_USER=saptechnologies256@gmail.com
GMAIL_PASS=your_gmail_app_password
# You may use SMTP_USER/SMTP_PASS instead of GMAIL_USER/GMAIL_PASS for any SMTP provider.

# ===========================================
# 📱 WHATSAPP NOTIFICATIONS (Optional)
# ===========================================

# Twilio WhatsApp Configuration
TWILIO_SID=your_twilio_sid
TWILIO_AUTH=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+your_number

# ===========================================
# ☁️  CLOUDINARY - CLOUD IMAGE STORAGE
# ===========================================

# Cloudinary Configuration (Recommended for Production)
# Sign up at: https://cloudinary.com (Free tier: 25GB storage, 25GB bandwidth/month)
# Get credentials from: Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Benefits:
# - Automatic image optimization (WebP, quality, size)
# - Global CDN delivery for fast loading
# - No storage on server (saves disk space)
# - Image transformations (resize, crop, filters)
# - Reliable and scalable

# ===========================================
# 🌐 CLIENT & CORS CONFIGURATION
# ===========================================

# Frontend URLs (for CORS)
CLIENT_URL=https://saptechug.com
PRODUCTION_CLIENT_URL=https://saptechug.com
API_PUBLIC_URL=https://sap-technologies-ug.onrender.com

# Allowed Origins (comma-separated)
# Include both www and non-www variants, plus localhost for development
ALLOWED_ORIGINS=https://saptechug.com,https://www.saptechug.com,https://sap-technologies.com,https://www.sap-technologies.com,http://localhost:5174,https://localhost:5174

# ===========================================
# 🔒 SSL/TLS CONFIGURATION (Production)
# ===========================================

# SSL Certificate Paths (Production only)
SSL_KEY_PATH=/path/to/private-key.pem
SSL_CERT_PATH=/path/to/certificate.pem
SSL_CA_PATH=/path/to/ca-certificate.pem

# Force HTTPS in production
FORCE_HTTPS=false

# ===========================================
# 📊 LOGGING & MONITORING
# ===========================================

# Log Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log
ERROR_LOG_FILE=logs/error.log
SECURITY_LOG_FILE=logs/security.log

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# ===========================================
# 🚨 SECURITY LIMITS
# ===========================================

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_MAX=3

# File Upload Limits
MAX_FILE_SIZE=5242880
MAX_FILES_PER_REQUEST=10

# Request Limits
MAX_REQUEST_SIZE=1mb
MAX_PARAMETERS=20

# ===========================================
# 🔧 ADMIN CONFIGURATION
# ===========================================

# Default Admin User
ADMIN_EMAIL=admin@sap-technologies.com
ADMIN_PASSWORD=generate_secure_password_here
ADMIN_NAME=System Administrator

# Admin Security
ADMIN_SESSION_TIMEOUT=30
ADMIN_MAX_LOGIN_ATTEMPTS=3

# ===========================================
# 🎯 DEVELOPMENT SETTINGS
# ===========================================

# Development Only
DEBUG=false
ENABLE_SWAGGER=false
ENABLE_CORS_ALL=false
